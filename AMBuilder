import os

project = builder.LibraryProject('l4dtoolz')
project.sources += [
  'l4dtoolz_mm.cpp',
  'memutils.cpp',
]
  
for sdk_name in Extension.sdks:
  sdk = Extension.sdks[sdk_name]
  if sdk['name'] in ['mock']:
    continue

  for cxx in builder.targets:
    if not cxx.target.arch in sdk['platforms'][cxx.target.platform]:
      continue
    
    binary = Extension.HL2Config(project, builder, cxx, 'l4dtoolz_mm', sdk)

Extension.extensions = builder.Add(project)
